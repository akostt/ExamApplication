<Window x:Class="ExamApplication.InputDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExamApplication"
        mc:Ignorable="d"
        Title="InputDialogWindow" Height="230" Width="722">
    <Grid>
        <Label Content="Аэропорт отправления" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="AeroportOutInput" HorizontalAlignment="Left" Margin="153,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="165"/>
        <Label Content="Аэропорт прибытия" HorizontalAlignment="Left" Margin="356,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="AeroportInInput" HorizontalAlignment="Left" Margin="489,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="165"/>
        <Label Content="Время отправления" HorizontalAlignment="Left" Margin="10,54,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TimeArriveInput" HorizontalAlignment="Left" Margin="153,58,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="165"/>
        <Button x:Name="ApplyButton" Content="Применить" HorizontalAlignment="Left" Margin="24,123,0,0" VerticalAlignment="Top" Height="34" Width="212" Click="ApplyButton_Click"/>
        <Button x:Name="CancelButton" Content="Отмена" HorizontalAlignment="Left" Margin="466,123,0,0" VerticalAlignment="Top" Height="34" Width="212" Click="CancelButton_Click"/>

    </Grid>
</Window>
